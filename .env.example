# AI Studio Applet Environment Configuration
# Define all environment variables here with empty values (e.g. KEY=) to allow runtime injection.

# Gemini AI API
GEMINI_API_KEY=

# Hosted Application URL (Injected automatically at runtime)
APP_URL=

# Cloud SQL Dev/Runtime Database Connection Variables
SQL_HOST=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=

# Drizzle Kit Schema Administration Credentials
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=
