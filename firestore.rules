rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'preferredLanguage', 'updatedAt']) 
        && data.keys().size() == 3
        && data.uid is string
        && data.uid == request.auth.uid
        && data.preferredLanguage is string
        && (data.preferredLanguage == 'en' || data.preferredLanguage == 'hi')
        && data.updatedAt is string;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidId(userId) && isValidUserProfile(request.resource.data);
    }
  }
}
